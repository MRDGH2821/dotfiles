{
  "goTemplateBracketSpacing": true,
  "overrides": [
    {
      "files": ["*.jsonc", "*.json"],
      "options": {
        "parser": "json",
        "trailingComma": "none"
      }
    },
    {
      "files": [
        "konsolerc",
        "dolphinrc",
        ".editorconfig",
        "**/git/config",
        "dot_shellcheckrc",
        "**/konsole/*.profile"
      ],
      "options": {
        "parser": "ini"
      }
    },
    {
      "files": ["*.sh", "**/.envrc", "dot_zshrc", "dot_bashrc", "dot_zshenv"],
      "options": {
        "parser": "sh",
        "spaceRedirects": false
      }
    },
    {
      "files": ["*.xml", "**/dolphinui.rc"],
      "options": {
        "parser": "xml"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-go-template",
    "prettier-plugin-ini",
    "prettier-plugin-powershell",
    "prettier-plugin-toml",
    "@prettier/plugin-xml",
    "prettier-plugin-sh"
  ],
  "powershellIndentSize": 2,
  "powershellRewriteAliases": true,
  "powershellRewriteWriteHost": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false
}
