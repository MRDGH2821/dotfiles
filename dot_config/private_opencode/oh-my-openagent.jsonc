{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "fallback_models": ["opencode/gpt-5-nano"],
      "model": "zai-coding-plan/glm-5.1"
    },
    "explore": {
      "model": "opencode/gpt-5-nano"
    },
    "librarian": {
      "model": "zai-coding-plan/glm-4.7"
    },
    "metis": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "momus": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "multimodal-looker": {
      "fallback_models": ["zai-coding-plan/glm-4.6v", "opencode/gpt-5-nano"],
      "model": "zai-coding-plan/glm-5v-turbo"
    },
    "oracle": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "prometheus": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "sisyphus": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "sisyphus-junior": {
      "fallback_models": ["opencode/gpt-5-nano"],
      "model": "zai-coding-plan/glm-4.7"
    }
  },
  "auto_update": true,
  "categories": {
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "deep": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "quick": {
      "model": "opencode/gpt-5-nano"
    },
    "ultrabrain": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "unspecified-high": {
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },
    "unspecified-low": {
      "model": "opencode/gpt-5-nano"
    },
    "visual-engineering": {
      "fallback_models": ["zai-coding-plan/glm-5.1"],
      "model": "zai-coding-plan/glm-5v-turbo"
    },
    "writing": {
      "model": "opencode/gpt-5-nano"
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  },
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  }
}
