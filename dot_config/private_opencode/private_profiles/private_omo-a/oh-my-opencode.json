{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "fallback_models": ["zai-coding-plan/glm-4.7", "opencode/big-pickle"],
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "build": {
      "fallback_models": ["opencode/big-pickle"],
      "model": "opencode/gpt-5-nano"
    },
    "explore": {
      "fallback_models": [
        "github-copilot/gemini-3-flash",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/grok-code-fast-1"
    },
    "hephaestus": {
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/gpt-5.1-codex"
      ],
      "model": "cursor/gpt-5.4",
      "variant": "medium"
    },
    "librarian": {
      "fallback_models": [
        "github-copilot/gemini-3.1-pro",
        "cursor/gemini-3.1-pro",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/grok-code-fast-1"
    },
    "metis": {
      "fallback_models": ["zai-coding-plan/glm-5.1"],
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    },
    "momus": {
      "fallback_models": [
        {
          "model": "cursor/gpt-5.4",
          "variant": "xhigh"
        },
        "github-copilot/gpt-5.3-codex",
        "zai-coding-plan/glm-5.1"
      ],
      "model": "github-copilot/gpt-5.1-codex",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "fallback_models": [
        "cursor/gemini-3.1-pro",
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-4.6v"
      ],
      "model": "github-copilot/gemini-3.1-pro"
    },
    "oracle": {
      "fallback_models": [
        {
          "model": "cursor/gpt-5.4",
          "variant": "high"
        },
        "github-copilot/gpt-5.1-codex",
        "zai-coding-plan/glm-5"
      ],
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "high"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel. Focus on decision completeness - leave zero decisions to implementer.",
      "variant": "max"
    },
    "sisyphus": {
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "cursor/claude-4.6-opus",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    }
  },
  "background_task": {
    "defaultConcurrency": 8,
    "modelConcurrency": {
      "cursor/claude-4.6-opus": 2,
      "cursor/gemini-3.1-pro": 3,
      "cursor/gpt-5.4": 2,
      "github-copilot/claude-opus-4.6": 2,
      "github-copilot/gemini-2.5-pro": 4,
      "github-copilot/gemini-3-flash": 8,
      "github-copilot/gemini-3.1-pro": 4,
      "github-copilot/grok-code-fast-1": 10,
      "opencode/big-pickle": 20
    },
    "providerConcurrency": {
      "cursor": 3,
      "github-copilot": 5,
      "opencode": 15,
      "zai-coding-plan": 8
    },
    "staleTimeoutMs": 180000
  },
  "categories": {
    "artistry": {
      "fallback_models": [
        "github-copilot/gemini-3.1-pro",
        "github-copilot/claude-opus-4.6"
      ],
      "model": "cursor/gemini-3.1-pro",
      "variant": "high"
    },
    "deep": {
      "fallback_models": [
        "github-copilot/gpt-5.1-codex",
        "zai-coding-plan/glm-5",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium"
    },
    "quick": {
      "fallback_models": [
        "github-copilot/gemini-3-flash",
        "opencode/big-pickle"
      ],
      "model": "opencode/gpt-5-nano"
    },
    "ultrabrain": {
      "fallback_models": [
        {
          "model": "cursor/gpt-5.4",
          "variant": "xhigh"
        },
        "github-copilot/gpt-5.3-codex",
        "github-copilot/claude-opus-4.6"
      ],
      "model": "github-copilot/gpt-5.1-codex",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "cursor/claude-4.6-opus",
        "cursor/gemini-3.1-pro"
      ],
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    },
    "unspecified-low": {
      "fallback_models": [
        "github-copilot/gemini-3-flash",
        "zai-coding-plan/glm-4.7",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "visual-engineering": {
      "fallback_models": [
        "github-copilot/gemini-3.1-pro",
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-5"
      ],
      "model": "cursor/gemini-3.1-pro",
      "variant": "high"
    },
    "writing": {
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "cursor/gemini-3.1-pro",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gemini-3.1-pro"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "task_system": true
  },
  "git_master": {
    "commit_footer": true,
    "git_env_prefix": "GIT_MASTER=1",
    "include_co_authored_by": true
  },
  "google_auth": false,
  "hashline_edit": true,
  "runtime_fallback": {
    "cooldown_seconds": 60,
    "enabled": true,
    "max_fallback_attempts": 3,
    "notify_on_fallback": true,
    "retry_on_errors": [400, 429, 503, 529],
    "timeout_seconds": 30
  },
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "tmux": {
    "enabled": false
  }
}
