{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "Devenv": {
      "command": ["devenv", "mcp"],
      "enabled": true,
      "type": "local"
    },
    "engram": {
      "command": ["engram", "mcp", "--tools=agent"],
      "enabled": true,
      "type": "local"
    },
    "SiteMCP (Devenv)": {
      "command": ["bunx", "sitemcp", "https://devenv.sh/"],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "opencode/big-pickle",
  "plugin": [
    "@simonwjackson/opencode-direnv",
    "cursor-acp",
    "oh-my-openagent@latest",
    "opencode-with-claude@latest"
  ],
  "provider": {
    "cursor-acp": {
      "models": {
        // ── Standalone ────────────────────────────────────────────────────────
        "auto": {
          "name": "Auto"
        },

        // ── Claude ───────────────────────────────────────────────────────────
        "claude-4-sonnet": {
          "name": "Sonnet 4",
          "variants": {
            "1m": {
              "name": "1M"
            },
            "1m-thinking": {
              "name": "1M Thinking"
            },
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "claude-4.5-opus-high": {
          "name": "Opus 4.5",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "claude-4.5-sonnet": {
          "name": "Sonnet 4.5 1M",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "claude-4.6-opus-high": {
          "name": "Opus 4.6 1M",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "claude-4.6-opus-max": {
          "name": "Opus 4.6 1M Max",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "claude-4.6-sonnet-medium": {
          "name": "Sonnet 4.6 1M",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "composer-1.5": {
          "name": "Composer 1.5"
        },

        // ── Composer ─────────────────────────────────────────────────────────
        "composer-2": {
          "name": "Composer 2",
          "variants": {
            "fast": {
              "name": "Fast"
            }
          }
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro"
        },
        "gpt-5-mini": {
          "name": "GPT-5 Mini"
        },

        // ── GPT-5.1 ──────────────────────────────────────────────────────────
        "gpt-5.1": {
          "name": "GPT-5.1",
          "variants": {
            "high": {
              "name": "High"
            },
            "low": {
              "name": "Low"
            }
          }
        },

        // All gpt-5.1-codex-max entries have an effort suffix → stem as base
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1 Codex Max",
          "variants": {
            "high": {
              "name": "High"
            },
            "high-fast": {
              "name": "High Fast"
            },
            "low": {
              "name": "Low"
            },
            "low-fast": {
              "name": "Low Fast"
            },
            "medium": {
              "name": "Medium"
            },
            "medium-fast": {
              "name": "Medium Fast"
            },
            "xhigh": {
              "name": "Extra High"
            },
            "xhigh-fast": {
              "name": "Extra High Fast"
            }
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "variants": {
            "high": {
              "name": "High"
            },
            "low": {
              "name": "Low"
            }
          }
        },

        // ── GPT-5.2 ──────────────────────────────────────────────────────────
        "gpt-5.2": {
          "name": "GPT-5.2",
          "variants": {
            "fast": {
              "name": "Fast"
            },
            "high": {
              "name": "High"
            },
            "high-fast": {
              "name": "High Fast"
            },
            "low": {
              "name": "Low"
            },
            "low-fast": {
              "name": "Low Fast"
            },
            "xhigh": {
              "name": "Extra High"
            },
            "xhigh-fast": {
              "name": "Extra High Fast"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "variants": {
            "fast": {
              "name": "Fast"
            },
            "high": {
              "name": "High"
            },
            "high-fast": {
              "name": "High Fast"
            },
            "low": {
              "name": "Low"
            },
            "low-fast": {
              "name": "Low Fast"
            },
            "xhigh": {
              "name": "Extra High"
            },
            "xhigh-fast": {
              "name": "Extra High Fast"
            }
          }
        },

        // ── GPT-5.3 ──────────────────────────────────────────────────────────
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "variants": {
            "fast": {
              "name": "Fast"
            },
            "high": {
              "name": "High"
            },
            "high-fast": {
              "name": "High Fast"
            },
            "low": {
              "name": "Low"
            },
            "low-fast": {
              "name": "Low Fast"
            },
            "xhigh": {
              "name": "Extra High"
            },
            "xhigh-fast": {
              "name": "Extra High Fast"
            }
          }
        },
        "gpt-5.3-codex-spark-preview": {
          "name": "GPT-5.3 Codex Spark",
          "variants": {
            "high": {
              "name": "High"
            },
            "low": {
              "name": "Low"
            },
            "xhigh": {
              "name": "Extra High"
            }
          }
        },

        // ── GPT-5.4 (all entries have effort suffix → stem as base) ──────────
        "gpt-5.4": {
          "name": "GPT-5.4 1M",
          "variants": {
            "high": {
              "name": "High"
            },
            "high-fast": {
              "name": "High Fast"
            },
            "low": {
              "name": "Low"
            },
            "medium": {
              "name": "Medium"
            },
            "medium-fast": {
              "name": "Fast"
            },
            "xhigh": {
              "name": "Extra High"
            },
            "xhigh-fast": {
              "name": "Extra High Fast"
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "variants": {
            "high": {
              "name": "High"
            },
            "low": {
              "name": "Low"
            },
            "medium": {
              "name": "Medium"
            },
            "none": {
              "name": "None"
            },
            "xhigh": {
              "name": "Extra High"
            }
          }
        },
        "gpt-5.4-nano": {
          "name": "GPT-5.4 Nano",
          "variants": {
            "high": {
              "name": "High"
            },
            "low": {
              "name": "Low"
            },
            "medium": {
              "name": "Medium"
            },
            "none": {
              "name": "None"
            },
            "xhigh": {
              "name": "Extra High"
            }
          }
        },

        // ── Grok ─────────────────────────────────────────────────────────────
        "grok-4-20": {
          "name": "Grok 4.20",
          "variants": {
            "thinking": {
              "name": "Thinking"
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      },
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "small_model": "opencode/gpt-5-nano"
}
