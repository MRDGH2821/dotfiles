{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ============================================================
  // oh-my-openagent optimised config
  //
  // Provider coverage:
  //   cursor-acp      – Cursor subscription (Claude, GPT, Gemini, Kimi, Grok, Composer)
  //   github-copilot  – Copilot subscription (GPT, Gemini, Claude, Grok)
  //   zai-coding-plan – ZhipuAI GLM Coding Plan
  //   opencode        – Free/nano tier
  //
  // Fallback placement strategy (within each family):
  //   1. newer model + best capability/variant  (e.g. claude-4.6-opus-max, gpt-5.4 xhigh)
  //   2. newer model                            (e.g. claude-4.6-sonnet, gpt-5.3-codex)
  //   3. older model + best capability/variant  (e.g. claude-4.5-opus-high, gpt-5.1-codex-max)
  //   4. older model                            (e.g. claude-4-sonnet, glm-4.5-flash)
  //
  // Agent-model matching (from guide):
  //   Communicators  (Sisyphus, Metis, Atlas)      → Claude / Kimi / GLM / Composer
  //   Dual-prompt    (Prometheus, Atlas)            → Claude preferred; GPT supported
  //   Deep spec.     (Hephaestus, Oracle, Momus)   → GPT Codex (principle-driven)
  //   Utility        (Explore, Librarian, Sisy-Jr) → fastest/cheapest available
  //   Visual         (Multimodal Looker)            → Gemini / GLM-v
  // ============================================================

  "agents": {
    // ── Atlas (todo orchestrator / long sessions — dual-prompt) ─
    "atlas": {
      "fallback_models": [
        // Newer Claude-like
        "cursor-acp/kimi-k2.5",
        // GPT path (newer)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "medium"
        },
        // Older Claude + best → lighter
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        // GLM — newer + best → older
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "opencode/big-pickle",
        "opencode/nemotron-3-super-free"
      ],
      "model": "cursor-acp/claude-4.6-sonnet-medium"
    },

    // ── Explore (fast codebase grep) ──────────────────────────
    // Speed over intelligence — NEVER use Opus here.
    "explore": {
      "fallback_models": [
        // Newer nano/flash options (best speed first)
        "cursor-acp/gpt-5.4-nano",
        "cursor-acp/gpt-5.4-mini",
        "github-copilot/gpt-5.4-mini",
        // Haiku — newer fast Claude
        "github-copilot/claude-haiku-4.5",
        // GLM flash — newer + best → older
        "zai-coding-plan/glm-4.7-flashx",
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.5-flash",
        // Free ultra-cheap
        "opencode/minimax-m2.5-free",
        "opencode/gpt-5-nano"
      ],
      "model": "github-copilot/grok-code-fast-1",
      "permission": {
        "bash": "ask",
        "edit": "deny"
      }
    },

    // ── Hephaestus (deep autonomous coder) ────────────────────
    // GPT-principle-driven ONLY — do NOT override to Claude.
    "hephaestus": {
      "fallback_models": [
        // 5.3-codex variants (newer + best → lighter)
        "cursor-acp/gpt-5.3-codex-spark-preview",
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        // 5.4 non-codex (newer gen but less code-specialised)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "high"
        },
        // 5.2-codex (older codex + best → copilot mirror)
        {
          "model": "cursor-acp/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        // 5.1-codex (older codex + best → mini)
        {
          "model": "cursor-acp/gpt-5.1-codex-max",
          "reasoningEffort": "high"
        },
        "cursor-acp/gpt-5.1-codex-mini",
        // Non-codex GPT fallbacks (older)
        {
          "model": "cursor-acp/gpt-5.2",
          "reasoningEffort": "high"
        },
        {
          "model": "cursor-acp/gpt-5.1",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.2",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.1",
          "reasoningEffort": "high"
        },
        // GLM emergency fallbacks
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "zai-coding-plan/glm-5",
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gpt-5.3-codex",
      "permission": {
        "bash": {
          "bun": "allow",
          "git": "allow",
          "npm": "allow",
          "test": "allow"
        },
        "edit": "allow"
      },
      "prompt_append": "You own the implementation. Use LSP, AST-grep, and hashline aggressively. Own the codebase end-to-end.",
      "reasoningEffort": "high"
    },

    // ── Librarian (docs & code search) ────────────────────────
    "librarian": {
      "fallback_models": [
        // Newer nano (fastest paid)
        "cursor-acp/gpt-5.4-nano",
        "cursor-acp/gpt-5.4-mini",
        "github-copilot/gpt-5.4-mini",
        // GLM flash — newer + fast → older
        "zai-coding-plan/glm-4.7-flashx",
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.5-flash",
        // Free
        "opencode/minimax-m2.5-free",
        "opencode/gpt-5-nano",
        "github-copilot/claude-haiku-4.5"
      ],
      "model": "github-copilot/grok-code-fast-1"
    },

    // ── Metis (plan gap analyzer) ──────────────────────────────
    "metis": {
      "fallback_models": [
        // Claude 4.6 — newer + best → lighter
        "cursor-acp/claude-4.6-opus-high",
        "cursor-acp/claude-4.6-sonnet-medium",
        // Claude 4.5 — older + best → lighter
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        "cursor-acp/claude-4-sonnet",
        // GLM — newer + best → older
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5",
        // Cheap fallback
        "github-copilot/gpt-5-mini",
        "opencode/gpt-5-nano"
      ],
      "model": "cursor-acp/claude-4.6-opus-max"
    },

    // ── Momus (ruthless reviewer) ──────────────────────────────
    "momus": {
      "fallback_models": [
        // Newer GPT (best first)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "high"
        },
        "cursor-acp/gpt-5.3-codex-spark-preview",
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "cursor-acp/grok-4-20",
          "reasoningEffort": "high"
        },
        // Older GPT codex (best first)
        {
          "model": "cursor-acp/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        // Claude (newer + max → high)
        "cursor-acp/claude-4.6-opus-max",
        "cursor-acp/claude-4.6-opus-high",
        // GLM — newer → older
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5",
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gpt-5.3-codex",
      "prompt_append": "Focus on correctness, edge cases, security, test coverage, and naming clarity.",
      "reasoningEffort": "xhigh"
    },

    // ── Multimodal Looker (vision / UI review) ─────────────────
    // Gemini primary; GLM-v models for vision fallback.
    "multimodal-looker": {
      "fallback_models": [
        // Gemini 3.x — newer + pro → flash
        "github-copilot/gemini-3.1-pro-preview",
        "cursor-acp/gemini-3-flash",
        "github-copilot/gemini-3-flash-preview",
        // Gemini 2.5 — older + best
        "github-copilot/gemini-2.5-pro",
        // GLM vision — newer + best → older
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-4.6v",
        "zai-coding-plan/glm-4.5v",
        // GPT vision fallback
        "github-copilot/gpt-4o"
      ],
      "model": "cursor-acp/gemini-3.1-pro"
    },

    // ── Oracle (architecture consultant) ──────────────────────
    // GPT xhigh primary; Grok-4 and Gemini as strong architectural fallbacks.
    "oracle": {
      "fallback_models": [
        // Newer GPT codex (best → lighter)
        {
          "model": "cursor-acp/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        "cursor-acp/gpt-5.3-codex-spark-preview",
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        // Grok (newer, powerful reasoning)
        {
          "model": "cursor-acp/grok-4-20",
          "reasoningEffort": "high"
        },
        // Older GPT (best effort first)
        {
          "model": "github-copilot/gpt-5.2",
          "reasoningEffort": "xhigh"
        },
        {
          "model": "cursor-acp/gpt-5.2",
          "reasoningEffort": "high"
        },
        // Gemini (newer + pro first)
        {
          "model": "cursor-acp/gemini-3.1-pro",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "reasoningEffort": "high"
        },
        // Older Gemini
        {
          "model": "github-copilot/gemini-2.5-pro",
          "reasoningEffort": "high"
        },
        // GLM + free
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "zai-coding-plan/glm-5",
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gpt-5.4",
      "reasoningEffort": "xhigh"
    },

    // ── Prometheus (strategic planner — dual-prompt) ───────────
    // Claude primary; auto-switches to GPT prompt path at runtime.
    "prometheus": {
      "fallback_models": [
        // Claude 4.6 fallback
        "cursor-acp/claude-4.6-sonnet-medium",
        // GPT path (newer + best first)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "high"
        },
        // Gemini (newer + pro first)
        {
          "model": "cursor-acp/gemini-3.1-pro",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "reasoningEffort": "high"
        },
        // Claude 4.5 — older + best
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        // GLM — newer + best → older
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.4
        },
        "zai-coding-plan/glm-5",
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "low"
        },
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/claude-4.6-opus-high",
      "prompt_append": "Interview the user thoroughly. Identify scope ambiguities. Build a step-by-step, file-level plan before any execution.",
      "reasoningEffort": "medium"
    },

    // ── Sisyphus (main orchestrator) ──────────────────────────
    // Claude-family only — 1,100-line orchestration prompt needs mechanics-driven compliance.
    "sisyphus": {
      "fallback_models": [
        // Claude 4.6 — newer + best first
        "cursor-acp/claude-4.6-opus-high",
        "cursor-acp/claude-4.6-sonnet-medium",
        // Claude-like alternatives (newer)
        "cursor-acp/kimi-k2.5",
        "cursor-acp/composer-2",
        // Claude 4.5 — older + best first
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        // Older
        "cursor-acp/composer-1.5",
        "cursor-acp/claude-4-sonnet",
        // GLM family — newer + best → older
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        // GPT last resort
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "medium"
        },
        "opencode/big-pickle",
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "medium"
        }
      ],
      "model": "cursor-acp/claude-4.6-opus-max",
      "prompt_append": "Delegate implementation to hephaestus. Parallelize oracle + explore. Keep planning concise.",
      "ultrawork": {
        "model": "cursor-acp/claude-4.6-opus-max"
      }
    },

    // ── Sisyphus Junior (trivial tasks / category executor) ─────
    "sisyphus-junior": {
      "fallback_models": [
        // Newer nano/mini (faster paid)
        "cursor-acp/gpt-5.4-nano",
        "cursor-acp/gpt-5.4-mini",
        "github-copilot/gpt-5.4-mini",
        // Newer Claude sonnet (quality bump)
        "cursor-acp/claude-4.6-sonnet-medium",
        // Older (best → lighter)
        "cursor-acp/claude-4.5-sonnet",
        "cursor-acp/gpt-5-mini",
        "github-copilot/gpt-5-mini",
        // GLM flash — newer → older
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.5-flash",
        "opencode/minimax-m2.5-free"
      ],
      "model": "opencode/gpt-5-nano"
    }
  },

  // ─── BACKGROUND TASKS ───────────────────────────────────────

  "background_task": {
    "defaultConcurrency": 6,
    "modelConcurrency": {
      "cursor-acp/claude-4.6-opus-high": 2,
      "cursor-acp/claude-4.6-opus-max": 2,
      "cursor-acp/gpt-5.3-codex": 3,
      "cursor-acp/gpt-5.4": 3,
      "cursor-acp/grok-4-20": 2,
      "github-copilot/gpt-5.2": 3,
      "github-copilot/gpt-5.3-codex": 3,
      "github-copilot/grok-code-fast-1": 10,
      "opencode/gpt-5-nano": 25,
      "opencode/minimax-m2.5-free": 15,
      "opencode/nemotron-3-super-free": 5,
      "opencode/qwen3.6-plus-free": 5,
      "zai-coding-plan/glm-5": 6,
      "zai-coding-plan/glm-5.1": 6
    },
    "providerConcurrency": {
      "cursor-acp": 5,
      "github-copilot": 8,
      "opencode": 20,
      "zai-coding-plan": 10
    },
    "staleTimeoutMs": 180000
  },

  // ─── CATEGORIES ─────────────────────────────────────────────

  "categories": {
    // ── artistry ───────────────────────────────────────────────
    "artistry": {
      "description": "Creative solutions, lateral thinking, unconventional approaches",
      "fallback_models": [
        // Gemini (newer + pro → flash → older pro)
        "github-copilot/gemini-3.1-pro-preview",
        "cursor-acp/gemini-3-flash",
        "github-copilot/gemini-2.5-pro",
        // Claude (newer + best → lighter)
        "cursor-acp/claude-4.6-opus-high",
        "cursor-acp/claude-4.6-sonnet-medium",
        // GPT creative
        "cursor-acp/gpt-5.4",
        // Claude older
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        // GLM (newer → older)
        "zai-coding-plan/glm-4.7",
        "zai-coding-plan/glm-4.6",
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gemini-3.1-pro"
    },

    // ── deep ───────────────────────────────────────────────────
    "deep": {
      "description": "Multi-file refactors, autonomous deep-dives, research tasks",
      "fallback_models": [
        // 5.3-codex variants (newer + best → preview)
        "cursor-acp/gpt-5.3-codex-spark-preview",
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        // 5.4 non-codex (newer gen)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "medium"
        },
        // 5.2-codex (older codex + best first)
        {
          "model": "cursor-acp/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        // 5.1-codex (older codex + best → mini)
        {
          "model": "cursor-acp/gpt-5.1-codex-max",
          "reasoningEffort": "high"
        },
        "cursor-acp/gpt-5.1-codex-mini",
        // Claude fallback (newer + best)
        "cursor-acp/claude-4.6-opus-high",
        "cursor-acp/claude-4.5-opus-high",
        // GLM
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gpt-5.3-codex",
      "reasoningEffort": "high"
    },

    // ── git ────────────────────────────────────────────────────
    "git": {
      "description": "Git operations — commits, rebases, diff summaries",
      "fallback_models": [
        // Newer (mini > nano within same gen)
        "cursor-acp/gpt-5.4-mini",
        "cursor-acp/gpt-5.4-nano",
        // Older flash
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.5-flash"
      ],
      "model": "opencode/gpt-5-nano",
      "prompt_append": "Atomic commits, conventional commit format, safe operations only."
    },

    // ── quick ──────────────────────────────────────────────────
    "quick": {
      "description": "Trivial single-line fixes, typos, boilerplate",
      "fallback_models": [
        // Newer (mini > nano within same gen)
        "cursor-acp/gpt-5.4-mini",
        "cursor-acp/gpt-5.4-nano",
        "github-copilot/gpt-5.4-mini",
        // Older mini (best → standard)
        "cursor-acp/gpt-5-mini",
        "github-copilot/gpt-5-mini",
        // GLM flash (newer → older)
        "zai-coding-plan/glm-4.7-flashx",
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.5-flash"
      ],
      "model": "opencode/gpt-5-nano"
    },

    // ── ultrabrain ─────────────────────────────────────────────
    "ultrabrain": {
      "description": "Architecture decisions, algorithm design, complex debugging",
      "fallback_models": [
        // Newer GPT codex (best first)
        {
          "model": "cursor-acp/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        "cursor-acp/gpt-5.3-codex-spark-preview",
        {
          "model": "cursor-acp/grok-4-20",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        // Older GPT (best effort)
        {
          "model": "github-copilot/gpt-5.2",
          "reasoningEffort": "xhigh"
        },
        {
          "model": "cursor-acp/gpt-5.2",
          "reasoningEffort": "high"
        },
        // Gemini (newer + pro → older)
        {
          "model": "cursor-acp/gemini-3.1-pro",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gemini-2.5-pro",
          "reasoningEffort": "high"
        },
        // Claude (newer + max)
        "cursor-acp/claude-4.6-opus-max",
        // Free reasoning
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/gpt-5.4",
      "reasoningEffort": "xhigh"
    },

    // ── unspecified-high ───────────────────────────────────────
    "unspecified-high": {
      "fallback_models": [
        // Newer Claude (best → lighter)
        "cursor-acp/claude-4.6-sonnet-medium",
        "cursor-acp/kimi-k2.5",
        // GPT (newer + high effort)
        {
          "model": "cursor-acp/gpt-5.4",
          "reasoningEffort": "high"
        },
        {
          "model": "cursor-acp/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        // Older Claude (best → lighter)
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        // Older GPT
        {
          "model": "github-copilot/gpt-5.1",
          "reasoningEffort": "high"
        },
        // GLM (newer → older)
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "zai-coding-plan/glm-5",
        // Free reasoning
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/claude-4.6-opus-high"
    },

    // ── unspecified-low ────────────────────────────────────────
    "unspecified-low": {
      "fallback_models": [
        // Newer Claude-like alternatives
        "cursor-acp/kimi-k2.5",
        // Older Claude (best → lighter → oldest)
        "cursor-acp/claude-4.5-opus-high",
        "cursor-acp/claude-4.5-sonnet",
        "cursor-acp/claude-4-sonnet",
        // GLM (newer + best → older)
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-4.7",
        // Light GPT
        {
          "model": "cursor-acp/gpt-5.2",
          "reasoningEffort": "low"
        },
        "cursor-acp/gemini-3-flash",
        "opencode/big-pickle"
      ],
      "model": "cursor-acp/claude-4.6-sonnet-medium"
    },

    // ── visual-engineering ─────────────────────────────────────
    "visual-engineering": {
      "description": "Frontend, UI/UX, CSS, animations, visual debugging",
      "fallback_models": [
        // Gemini 3.x — newer + pro → flash
        "github-copilot/gemini-3.1-pro-preview",
        "cursor-acp/gemini-3-flash",
        "github-copilot/gemini-3-flash-preview",
        // Gemini 2.5 — older + pro (best of older gen)
        "github-copilot/gemini-2.5-pro",
        // GLM vision — newer + best → older
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-4.6v",
        "zai-coding-plan/glm-4.5v",
        // GPT vision
        "github-copilot/gpt-4o"
      ],
      "model": "cursor-acp/gemini-3.1-pro"
    },

    // ── writing ────────────────────────────────────────────────
    "writing": {
      "description": "Docs, READMEs, changelogs, commit messages, technical writing",
      "fallback_models": [
        // Gemini (newer + pro → preview → older pro)
        "cursor-acp/gemini-3.1-pro",
        "github-copilot/gemini-3.1-pro-preview",
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/gemini-2.5-pro",
        // Claude (newer + lighter writing model)
        "cursor-acp/kimi-k2.5",
        "cursor-acp/claude-4.6-sonnet-medium",
        "cursor-acp/claude-4.5-sonnet",
        // GLM (newer → older)
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5",
        "opencode/gpt-5-nano"
      ],
      "model": "cursor-acp/gemini-3-flash"
    }
  },

  // ─── EXPERIMENTAL ────────────────────────────────────────────
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        },
        "supersede_writes": {
          "aggressive": false,
          "enabled": true
        }
      },
      "turn_protection": {
        "enabled": true,
        "turns": 4
      }
    },
    "task_system": true
  },
  "git_master": {
    "commit_footer": true,
    "git_env_prefix": "GIT_MASTER=1",
    "include_co_authored_by": true
  },
  "hashline_edit": true,
  "model_capabilities": {
    "auto_refresh_on_start": true,
    "enabled": true,
    "refresh_timeout_ms": 5000
  },
  "runtime_fallback": {
    "cooldown_seconds": 45,
    "enabled": true,
    "max_fallback_attempts": 4,
    "notify_on_fallback": true,
    "retry_on_errors": [400, 429, 503, 529],
    "timeout_seconds": 30
  },
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "tmux": {
    "enabled": false
  }
}
