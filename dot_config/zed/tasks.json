[
  {
    "args": ["-vv"],
    "command": "treefmt",
    "hide": "on_success",
    "label": "Format with treefmt",
    "reveal_target": "center",
    "show_command": true,
    "tags": ["format"]
  },
  {
    "allow_concurrent_runs": false,
    "command": "xdg-open http://127.0.0.1:23635/",
    "hide": "always",
    "label": "Open Typst Preview",
    "reveal": "never",
    "reveal_target": "dock",
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["build"],
    "use_new_terminal": true
  },
  {
    "args": ["difftool", "--dir-diff"],
    "command": "git",
    "hide": "on_success",
    "label": "Meld dir diff"
  },
  {
    "args": ["difftool", "$ZED_FILE", "-y"],
    "command": "git",
    "hide": "on_success",
    "label": "Meld file diff"
  },
  {
    "command": "lazygit -p $ZED_WORKTREE_ROOT",
    "hide": "on_success",
    "label": "Start Lazygit"
  },
  {
    "args": ["copy", "gh:MRDGH2821/copier-mr-minimal"],
    "command": "copier",
    "hide": "on_success",
    "label": "Initialise with copier template"
  },
  {
    "args": ["update"],
    "command": "copier",
    "hide": "on_success",
    "label": "Update copier template"
  }
]
