{
  "goTemplateBracketSpacing": true,
  "overrides": [
    {
      "files": ["*.jsonc", "*.json"],
      "options": {
        "parser": "json",
        "trailingComma": "none"
      }
    },
    {
      "files": ["private_konsolerc", "private_dolphinrc", ".editorconfig"],
      "options": {
        "parser": "ini"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-powershell",
    "prettier-plugin-toml",
    "prettier-plugin-ini"
  ],
  "powershellIndentSize": 2,
  "powershellRewriteAliases": true,
  "powershellRewriteWriteHost": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false
}
