[
  {
    "bindings": {
      "alt-shift-f": "editor::Format"
    },
    "context": "Editor"
  },
  {
    "bindings": {
      "ctrl-p": ["terminal::SendKeystroke", "ctrl-p"],
      "ctrl-t": ["terminal::SendKeystroke", "ctrl-t"],
      "ctrl-x": ["terminal::SendKeystroke", "ctrl-x"]
    },
    "context": "Terminal"
  },
  {
    "bindings": {
      "alt-z": "editor::ToggleSoftWrap"
    },
    "context": "(Editor && mode == full)"
  },
  {
    "bindings": {
      "alt-g": [
        "task::Spawn",
        {
          "reveal_target": "center",
          "task_name": "Start Lazygit"
        }
      ],
      "alt-m": [
        "task::Spawn",
        {
          "task_name": "Meld file diff"
        }
      ],
      "alt-shift-m": [
        "task::Spawn",
        {
          "task_name": "Meld dir diff"
        }
      ]
    },
    "context": "Workspace"
  },
  {
    "bindings": {
      "super-shift-f": [
        "task::Spawn",
        {
          "reveal_target": "center",
          "task_name": "Format with treefmt"
        }
      ]
    },
    "context": "Workspace"
  },
  {
    "bindings": {
      "alt-o": [
        "task::Spawn",
        {
          "reveal_target": "center",
          "task_name": "Start OpenCode"
        }
      ]
    },
    "context": "Workspace"
  }
]
