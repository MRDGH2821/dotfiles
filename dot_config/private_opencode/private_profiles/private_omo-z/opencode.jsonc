{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "small_model": "opencode/gpt-5-nano",
  "plugin": ["oh-my-opencode@latest", "@simonwjackson/opencode-direnv"],
  "mcp": {
    "SiteMCP (Devenv)": {
      "command": ["bunx", "sitemcp", "https://devenv.sh/"],
      "enabled": true,
      "type": "local"
    }
  }
}
