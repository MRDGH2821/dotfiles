{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "Devenv": {
      "command": ["devenv", "mcp"],
      "enabled": true,
      "type": "local"
    },
    "engram": {
      "command": ["engram", "mcp", "--tools=agent"],
      "enabled": true,
      "type": "local"
    },
    "SiteMCP (Devenv)": {
      "command": ["bunx", "sitemcp", "https://devenv.sh/"],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "opencode/big-pickle",
  "plugin": [
    "@simonwjackson/opencode-direnv",
    "oh-my-openagent@latest",
    "opencode-cursor-oauth@latest"
    // "opencode-with-claude@latest"
  ],
  "provider": {
    "cursor": {
      "name": "Cursor"
    }
  },
  "small_model": "opencode/gpt-5-nano"
}
