{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ============================================================
  // oh-my-openagent optimised config by Mihir Rabade
  //
  // Provider coverage:
  //   opencode       – free/nano tier: big-pickle, gpt-5-nano,
  //                    minimax-m2.5-free, nemotron-3-super-free,
  //                    qwen3.6-plus-free
  //   github-copilot – Copilot subscription models
  //   zai-coding-plan – ZhipuAI GLM Coding Plan models
  //
  // Design principles:
  //   1. Best available model per role (based on benchmarks)
  //   2. Fallback chains cross providers for resilience
  //   3. Duplicate models across providers added as fallbacks
  //   4. Free / cheap models used where quality allows
  //   5. Reasoning effort tuned per use-case
  // ============================================================

  // ─── AGENTS ─────────────────────────────────────────────────

  "agents": {
    // ── Atlas (long-running autonomous sessions) ───────────────
    // Needs sustained quality over many turns. GLM-5 handles long ctx well.
    "atlas": {
      "fallback_models": [
        "zai-coding-plan/glm-5",
        {
          "model": "github-copilot/gpt-5.2",
          "reasoningEffort": "medium"
        },
        "opencode/big-pickle",
        "opencode/nemotron-3-super-free"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },

    // ── Explore (fast codebase navigation) ────────────────────
    // Same profile as Librarian but focused on grepping source trees.
    // Haiku-4.5 is ultra-fast Anthropic; GLM flash models are free.
    "explore": {
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "zai-coding-plan/glm-4.5-flash",
        "opencode/gpt-5-nano",
        "opencode/minimax-m2.5-free"
      ],
      "model": "github-copilot/grok-code-fast-1",
      "permission": {
        "bash": "ask",
        "edit": "deny"
      }
    },

    // ── Hephaestus (deep autonomous coder) ────────────────────
    // GPT-5.3-codex is the best pure-coding model in the list.
    // Falls back to GPT-5.2-codex (same lineage), then GLM-5.1.
    "hephaestus": {
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.1",
          "reasoningEffort": "medium"
        },
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "zai-coding-plan/glm-5",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "bash": {
          "bun": "allow",
          "git": "allow",
          "npm": "allow",
          "test": "allow"
        },
        "edit": "allow"
      },
      "prompt_append": "You own the implementation. Use LSP, AST-grep, and hashline aggressively. Own the codebase end-to-end.",
      "reasoningEffort": "high"
    },

    // ── Librarian (docs & code search) ────────────────────────
    // Speed matters most here. Grok-code-fast-1 is the fastest in the list.
    // GLM-4.7-flash / minimax-m2.5-free are free fast fallbacks.
    "librarian": {
      "fallback_models": [
        "zai-coding-plan/glm-4.7-flash",
        "zai-coding-plan/glm-4.7-flashx",
        "opencode/minimax-m2.5-free",
        "opencode/gpt-5-nano",
        "github-copilot/claude-haiku-4.5"
      ],
      "model": "github-copilot/grok-code-fast-1"
    },

    // ── Metis (plan consultant) ────────────────────────────────
    // Quick plan review; moderate quality is fine.
    "metis": {
      "fallback_models": [
        "github-copilot/gpt-5-mini",
        "github-copilot/gpt-5.4-mini",
        "opencode/gpt-5-nano"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },

    // ── Momus (code reviewer) ──────────────────────────────────
    // Code review benefits from codex-grade reasoning.
    "momus": {
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "medium"
        },
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.3-codex",
      "prompt_append": "Focus on correctness, edge cases, security, test coverage, and naming clarity.",
      "reasoningEffort": "high"
    },

    // ── Multimodal Looker (visual / UI review) ─────────────────
    // Gemini-3.1-pro-preview is the best vision model in the list.
    // GLM-5v-turbo and GLM-4.6v are vision-capable fallbacks.
    "multimodal-looker": {
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-4.6v",
        "zai-coding-plan/glm-4.5v",
        "github-copilot/gpt-4o"
      ],
      "model": "github-copilot/gemini-3.1-pro-preview"
    },

    // ── Oracle (architecture & debugging) ─────────────────────
    // Hard logical reasoning. GPT-5.2 + xhigh effort is ideal.
    // Nemotron-3 is NVIDIA's free reasoning model — strong fallback.
    "oracle": {
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "xhigh"
    },

    // ── Prometheus (strategic planner) ────────────────────────
    // Planning needs strong reasoning but not max throughput.
    // GPT-5.1 reasoning is ideal. Falls back to GLM-5 / Qwen3.
    "prometheus": {
      "fallback_models": [
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.4
        },
        "zai-coding-plan/glm-5",
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "low"
        },
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.1",
      "prompt_append": "Interview the user thoroughly. Identify scope ambiguities. Build a step-by-step, file-level plan before any execution.",
      "reasoningEffort": "medium"
    },

    // ── Sisyphus (main orchestrator) ──────────────────────────
    // Best orchestrator: needs strong reasoning + long context.
    // GPT-5.2 from Copilot is the top pick from the allowed list.
    // big-pickle handles extreme fallback (Copilot down / rate-limited).
    "sisyphus": {
      "fallback_models": [
        // GLM-5 as refined secondary ZAI fallback
        "zai-coding-plan/glm-5",
        // big-pickle is the catch-all free fallback
        "opencode/big-pickle",
        // Qwen reasoning as last resort
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "medium"
        }
      ],
      "model": "zai-coding-plan/glm-5.1",
      "prompt_append": "Delegate implementation to hephaestus. Parallelize oracle + explore. Keep planning concise.",
      "ultrawork": {
        "model": "zai-coding-plan/glm-5.1"
      }
    },

    // ── Sisyphus Junior (trivial / quick-fix tasks) ────────────
    "sisyphus-junior": {
      "fallback_models": [
        "github-copilot/gpt-5.4-mini",
        "github-copilot/gpt-5-mini",
        "zai-coding-plan/glm-4.5-flash",
        "opencode/minimax-m2.5-free"
      ],
      "model": "opencode/gpt-5-nano"
    }
  },

  // ─── BACKGROUND TASKS ───────────────────────────────────────
  // High concurrency on free/cheap providers; conservative on premium.

  "background_task": {
    "defaultConcurrency": 6,
    "modelConcurrency": {
      "github-copilot/gpt-5.2": 3,
      "github-copilot/gpt-5.3-codex": 3,
      "github-copilot/grok-code-fast-1": 10,
      "opencode/gpt-5-nano": 25,
      "opencode/minimax-m2.5-free": 15,
      "opencode/nemotron-3-super-free": 5,
      "opencode/qwen3.6-plus-free": 5,
      "zai-coding-plan/glm-5": 6,
      "zai-coding-plan/glm-5.1": 6
    },
    "providerConcurrency": {
      "github-copilot": 8, // Copilot has generous limits
      "opencode": 20, // Free/nano models can run wide
      "zai-coding-plan": 10 // ZAI coding plan is subscription-based
    },
    "staleTimeoutMs": 180000
  },

  // ─── CATEGORIES ─────────────────────────────────────────────
  // These are what Sisyphus picks when delegating subtasks.

  "categories": {
    // ── artistry: creative / unconventional problem solving ────
    "artistry": {
      "description": "Creative solutions, lateral thinking, unconventional approaches",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview",
        "zai-coding-plan/glm-4.6",
        "zai-coding-plan/glm-4.7",
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gemini-2.5-pro"
    },

    // ── deep: autonomous research + end-to-end execution ──────
    "deep": {
      "description": "Multi-file refactors, autonomous deep-dives, research tasks",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "github-copilot/gpt-5.1",
          "reasoningEffort": "medium"
        },
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "high"
    },

    // ── git: commit ops, rebase, PR descriptions ───────────────
    "git": {
      "description": "Git operations — commits, rebases, diff summaries",
      "fallback_models": [
        "zai-coding-plan/glm-4.5-flash",
        "github-copilot/gpt-5.4-mini"
      ],
      "model": "opencode/gpt-5-nano",
      "prompt_append": "Atomic commits, conventional commit format, safe operations only."
    },

    // ── quick: typo fixes, single-line changes ─────────────────
    "quick": {
      "description": "Trivial single-line fixes, typos, boilerplate",
      "fallback_models": [
        "github-copilot/gpt-5.4-mini",
        "github-copilot/gpt-5-mini",
        "zai-coding-plan/glm-4.5-flash"
      ],
      "model": "opencode/gpt-5-nano"
    },

    // ── ultrabrain: architecture, hard logic decisions ─────────
    "ultrabrain": {
      "description": "Architecture decisions, algorithm design, complex debugging",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.3-codex",
          "reasoningEffort": "high"
        },
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        {
          "model": "opencode/qwen3.6-plus-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "xhigh"
    },

    // ── unspecified-high: complex general tasks ────────────────
    "unspecified-high": {
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.1",
          "reasoningEffort": "high"
        },
        {
          "model": "zai-coding-plan/glm-5.1",
          "temperature": 0.2
        },
        {
          "model": "opencode/nemotron-3-super-free",
          "reasoningEffort": "high"
        },
        "opencode/big-pickle"
      ],
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high"
    },

    // ── unspecified-low: general moderate-effort tasks ─────────
    "unspecified-low": {
      "fallback_models": [
        "zai-coding-plan/glm-5",
        {
          "model": "github-copilot/gpt-5.2",
          "reasoningEffort": "low"
        },
        "github-copilot/gpt-5.1",
        "opencode/big-pickle"
      ],
      "model": "zai-coding-plan/glm-5.1"
    },

    // ── visual-engineering: frontend, UI/UX, design ────────────
    // Gemini family excels at visual tasks; GLM-v models as backup.
    "visual-engineering": {
      "description": "Frontend, UI/UX, CSS, animations, visual debugging",
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "github-copilot/gemini-3-flash-preview",
        "zai-coding-plan/glm-5v-turbo",
        "zai-coding-plan/glm-4.6v",
        "github-copilot/gpt-4o"
      ],
      "model": "github-copilot/gemini-3.1-pro-preview"
    },

    // ── writing: docs, changelogs, technical prose ─────────────
    "writing": {
      "description": "Docs, READMEs, changelogs, commit messages, technical writing",
      "fallback_models": [
        "github-copilot/gemini-2.5-pro",
        "zai-coding-plan/glm-5.1",
        "github-copilot/gpt-5-mini",
        "opencode/gpt-5-nano"
      ],
      "model": "github-copilot/gemini-3-flash-preview"
    }
  },

  // ─── EXPERIMENTAL ────────────────────────────────────────────
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        },
        "supersede_writes": {
          "aggressive": false,
          "enabled": true
        }
      },
      "turn_protection": {
        "enabled": true,
        "turns": 4
      }
    },
    "task_system": true
  },
  "git_master": {
    "commit_footer": true,
    "git_env_prefix": "GIT_MASTER=1",
    "include_co_authored_by": true
  },

  // ─── HASHLINE EDIT ───────────────────────────────────────────
  // Hash-anchored edits prevent stale-line errors — always on.
  "hashline_edit": true,

  // ─── MODEL CAPABILITIES (auto-refresh) ───────────────────────
  "model_capabilities": {
    "auto_refresh_on_start": true,
    "enabled": true,
    "refresh_timeout_ms": 5000
  },

  // ─── RUNTIME FALLBACK ────────────────────────────────────────
  "runtime_fallback": {
    "cooldown_seconds": 45,
    "enabled": true,
    "max_fallback_attempts": 4,
    "notify_on_fallback": true,
    "retry_on_errors": [400, 429, 503, 529],
    "timeout_seconds": 30
  },

  // ─── SISYPHUS AGENT SETTINGS ─────────────────────────────────
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },

  // ─── TMUX (disabled by default — enable if in tmux) ──────────
  "tmux": {
    "enabled": false
  }
}
